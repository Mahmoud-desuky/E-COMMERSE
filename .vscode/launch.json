{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C#: E-COMMERSE Debug",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/E-COMMERSE/Properties/launchSettings.json"
        },
        {
            "type": "DotNetAutoAttach",
            "request": "launch",
            "name": ".NET Core Watch",
            "args": [],
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": ".Net Core Launch (web)",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}"
        },
        {
        "commandName": "Project",
        "dotnetRunMessages": true,
        "launchBrowser": true,
        "launchUrl": "swagger",
        "applicationUrl": "https://localhost:7039;http://localhost:5135",
        "environmentVariables": {
            "ASPNETCORE_ENVIRONMENT": "Development"
        }
        }
    ]
}
